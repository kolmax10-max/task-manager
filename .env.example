# PostgreSQL (локально: postgres://USER:PASSWORD@127.0.0.1:5432/DBNAME)
DATABASE_URL=postgresql://taskapp:secret@127.0.0.1:5432/taskmanager

# Каталог для вложений (по умолчанию ./data/uploads от корня проекта)
# UPLOAD_DIR=/var/www/task-manager/data/uploads

# Максимальный размер одного файла при загрузке (МБ), по умолчанию 50
# MAX_UPLOAD_MB=50

JWT_SECRET=your-secret-key-change-in-production

# Cloudflare Turnstile — без ключей регистрация в production отключена.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Опционально для локального dev
# PORT=3000
# NODE_ENV=production
