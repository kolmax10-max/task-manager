DATABASE_URL=postgresql://...
BLOB_READ_WRITE_TOKEN=vercel_blob_...
# Нужен и для больших файлов: прямая загрузка в Blob из браузера (не через 4 МБ лимит функции).
JWT_SECRET=your-secret-key-change-in-production

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
# На Vercel задайте оба ключа — без них регистрация в проде отключена.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
